<Page
    x:Class="CodeHarness.Desktop.Views.ShellPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:CodeHarness.Desktop.Controls"
    xmlns:views="using:CodeHarness.Desktop.Views">

    <Grid Background="{ThemeResource CodeHarnessBackgroundBrush}"
          MinWidth="1040"
          MinHeight="640">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="260" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="300" />
        </Grid.ColumnDefinitions>

        <!-- COLUMN 0 · LEFT SIDEBAR -->
        <controls:Sidebar x:Name="SidebarControl" Grid.Column="0" />

        <!-- COLUMN 1 · CHAT -->
        <views:ChatPage x:Name="Chat" Grid.Column="1" />

        <!-- COLUMN 2 · GIT TOOLS PANEL -->
        <Border Grid.Column="2"
                Background="{ThemeResource CodeHarnessContextPanelBrush}"
                BorderBrush="{ThemeResource CodeHarnessBorderBrush}"
                BorderThickness="1,0,0,0">
            <Grid Padding="0,0,0,14">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <!-- Header -->
                <Grid Grid.Row="0" Padding="18,16,18,12">
                    <TextBlock Text="变更" FontSize="14" FontWeight="SemiBold"
                               Foreground="{ThemeResource CodeHarnessPrimaryTextBrush}"
                               VerticalAlignment="Center" />
                </Grid>

                <!-- Tab Headers: 变更 / 文件 -->
                <Grid Grid.Row="1" Margin="18,0,18,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Border x:Name="ChangesTabHeader" Grid.Column="0"
                            Padding="0,8,0,8"
                            BorderBrush="{ThemeResource CodeHarnessAccentBrush}"
                            BorderThickness="0,0,0,2">
                        <TextBlock Text="变更" HorizontalAlignment="Center"
                                   FontSize="13" FontWeight="SemiBold"
                                   Foreground="{ThemeResource CodeHarnessPrimaryTextBrush}" />
                    </Border>
                    <Border x:Name="FilesTabHeader" Grid.Column="1"
                            Padding="0,8,0,8"
                            BorderBrush="Transparent"
                            BorderThickness="0,0,0,2">
                        <TextBlock Text="文件" HorizontalAlignment="Center"
                                   FontSize="13"
                                   Foreground="{ThemeResource CodeHarnessMutedTextBrush}" />
                    </Border>
                </Grid>

                <!-- Content: Changes tab (default visible) / Files tab (hidden) -->
                <ScrollViewer Grid.Row="2"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollMode="Disabled"
                              HorizontalScrollBarVisibility="Disabled">

                    <StackPanel>
                    <!-- CHANGES TAB -->
                    <StackPanel x:Name="ChangesTabContent" Margin="18,0,18,0">

                        <!-- Branch pill + merge/commit/push/pull buttons -->
                        <Border Margin="0,12,0,12"
                                CornerRadius="8"
                                Padding="10,8,10,8"
                                Background="{ThemeResource CodeHarnessCardBrush}"
                                BorderBrush="{ThemeResource CodeHarnessBorderBrush}"
                                BorderThickness="1">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="&#xE727;"
                                           FontFamily="Segoe MDL2 Assets" FontSize="13"
                                           Foreground="{ThemeResource CodeHarnessAccentBrush}"
                                           VerticalAlignment="Center" Margin="0,0,8,0" />
                                <TextBlock x:Name="GitBranchText" Grid.Column="1"
                                           Text="分支: main"
                                           FontSize="12" FontWeight="Medium"
                                           Foreground="{ThemeResource CodeHarnessPrimaryTextBrush}"
                                           VerticalAlignment="Center"
                                           TextTrimming="CharacterEllipsis" />
                            </Grid>
                        </Border>

                        <!-- Diff summary text (populated by C++) -->
                        <TextBlock x:Name="GitDiffText"
                                   Text=""
                                   FontSize="12"
                                   Foreground="{ThemeResource CodeHarnessMutedTextBrush}"
                                   Margin="0,0,0,8"
                                   TextWrapping="Wrap" />

                        <!-- File change list (populated by C++) -->
                        <StackPanel x:Name="GitFileList" Spacing="2">
                            <!-- Empty state -->
                            <TextBlock Text="暂无变更"
                                       Style="{StaticResource ContextItemMetaTextStyle}"
                                       Margin="0,8,0,0" />
                        </StackPanel>

                        <!-- Progress / completed steps (populated by C++) -->
                        <TextBlock x:Name="ProgressHeader"
                                   Text="进度"
                                   Style="{StaticResource SidebarSectionTextStyle}"
                                   Margin="0,16,0,4" />
                        <StackPanel x:Name="ProgressList" Spacing="2" />
                    </StackPanel>

                    <!-- FILES TAB (hidden by default) -->
                    <StackPanel x:Name="FilesTabContent"
                                Visibility="Collapsed"
                                Margin="18,12,18,0"
                                Spacing="4">
                        <TextBlock Text="工作区文件"
                                   Style="{StaticResource ContextItemMetaTextStyle}" />
                    </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </Grid>
        </Border>
    </Grid>
</Page>