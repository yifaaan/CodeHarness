<Page
    x:Class="CodeHarness.Desktop.Views.ShellPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:CodeHarness.Desktop.Controls"
    xmlns:views="using:CodeHarness.Desktop.Views">

    <Grid Background="{ThemeResource CodeHarnessBackgroundBrush}"
          MinWidth="1040"
          MinHeight="640">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="260" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="300" />
        </Grid.ColumnDefinitions>

        <!-- COLUMN 0 · LEFT SIDEBAR -->
        <controls:Sidebar x:Name="SidebarControl" Grid.Column="0" />

        <!-- COLUMN 1 · CHAT -->
        <views:ChatPage x:Name="Chat" Grid.Column="1" />

        <!-- COLUMN 2 · RIGHT CONTEXT PANEL -->
        <Border Grid.Column="2"
                Background="{ThemeResource CodeHarnessContextPanelBrush}"
                BorderBrush="{ThemeResource CodeHarnessBorderBrush}"
                BorderThickness="1,0,0,0">
            <Grid Padding="18,16,18,14">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <!-- Header -->
                <Grid Grid.Row="0" Margin="0,0,0,18">
                    <TextBlock Text="Context" FontSize="14" FontWeight="SemiBold"
                               Foreground="{ThemeResource CodeHarnessPrimaryTextBrush}" VerticalAlignment="Center" />
                    <Button Style="{StaticResource IconButtonStyle}"
                            HorizontalAlignment="Right"
                            Content="&#xE713;" FontFamily="Segoe MDL2 Assets"
                            Width="28" Height="28" />
                </Grid>

                <!-- Open files -->
                <StackPanel Grid.Row="1" Margin="0,0,0,18" Spacing="8">
                    <TextBlock Text="OPEN FILES" Style="{StaticResource ContextSectionTextStyle}" />
                    <StackPanel x:Name="OpenFilesList" Spacing="8">
                        <TextBlock Text="No files opened yet. Tools that read or write files will appear here."
                                   Style="{StaticResource ContextItemMetaTextStyle}"
                                   TextWrapping="Wrap" />
                    </StackPanel>
                </StackPanel>

                <!-- Usage -->
                <StackPanel Grid.Row="2" Margin="0,0,0,18" Spacing="8">
                    <TextBlock Text="USAGE" Style="{StaticResource ContextSectionTextStyle}" />
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Context" Style="{StaticResource ContextItemTextStyle}" />
                        <TextBlock x:Name="ContextValueText"
                                   Grid.Column="1" Text="0 / 128k"
                                   Style="{StaticResource ContextItemMetaTextStyle}" />
                    </Grid>
                    <ProgressBar x:Name="ContextProgressBar"
                                 Value="0" Maximum="100"
                                 CornerRadius="3"
                                 Height="6"
                                 Foreground="{ThemeResource CodeHarnessAccentBrush}"
                                 Background="{ThemeResource CodeHarnessHoverBrush}" />
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Steps" Style="{StaticResource ContextItemTextStyle}" />
                        <TextBlock x:Name="StepsValueText"
                                   Grid.Column="1" Text="0"
                                   Style="{StaticResource ContextItemMetaTextStyle}" />
                    </Grid>
                </StackPanel>

                <!-- Activity -->
                <StackPanel Grid.Row="3" Spacing="8">
                    <TextBlock Text="ACTIVITY" Style="{StaticResource ContextSectionTextStyle}" />
                    <StackPanel x:Name="ActivityList" Spacing="4">
                        <TextBlock Text="No recent activity. Start a chat to see tool calls and updates here."
                                   Style="{StaticResource ContextItemMetaTextStyle}"
                                   TextWrapping="Wrap" />
                    </StackPanel>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Page>
