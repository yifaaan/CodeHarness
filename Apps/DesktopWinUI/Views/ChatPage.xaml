<Page
    x:Class="CodeHarness.Desktop.Views.ChatPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:CodeHarness.Desktop.Controls">

    <Grid Background="{ThemeResource CodeHarnessMainSurfaceBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Compatibility names used by the existing code-behind setters. -->
        <StackPanel Visibility="Collapsed">
            <TextBlock x:Name="PageTitleText" Text="新对话" />
            <TextBlock x:Name="WorkspaceTabText" Text="CodeHarness" />
            <TextBlock x:Name="BranchTabText" Text="main" />
        </StackPanel>

        <Grid Grid.Row="0">
            <!-- Empty/new chat state -->
            <StackPanel x:Name="EmptyStatePanel"
                        VerticalAlignment="Center"
                        HorizontalAlignment="Center"
                        Orientation="Horizontal"
                        Spacing="12"
                        MaxWidth="760"
                        Padding="40,0,40,144">
                <Border Width="36"
                        Height="36"
                        CornerRadius="11"
                        Background="{ThemeResource CodeHarnessAccentBrush}"
                        VerticalAlignment="Center">
                    <TextBlock Text="C"
                               Foreground="#FFFFFFFF"
                               FontSize="19"
                               FontWeight="Bold"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center" />
                </Border>
                <TextBlock x:Name="WelcomeText"
                           Text="今天想让 CodeHarness 做什么？"
                           Style="{StaticResource HeroTextStyle}"
                           TextAlignment="Center"
                           TextWrapping="Wrap"
                           VerticalAlignment="Center"
                           MaxWidth="620" />
            </StackPanel>

            <!-- Transcript -->
            <ScrollViewer x:Name="MessagesScroll"
                          VerticalScrollBarVisibility="Auto"
                          Padding="0,28,0,24"
                          Visibility="Collapsed">
                <StackPanel x:Name="MessagesPanel"
                            Spacing="12"
                            MaxWidth="780"
                            HorizontalAlignment="Center" />
            </ScrollViewer>
        </Grid>

        <Grid Grid.Row="1"
              MaxWidth="760"
              HorizontalAlignment="Center"
              Margin="16,0,16,0">
            <TextBlock x:Name="StatusText"
                       Text="就绪"
                       HorizontalAlignment="Left"
                       FontSize="11"
                       Foreground="{ThemeResource CodeHarnessMutedTextBrush}" />
            <TextBlock x:Name="UsageText"
                       Text=""
                       HorizontalAlignment="Right"
                       FontSize="11"
                       Foreground="{ThemeResource CodeHarnessFaintTextBrush}" />
        </Grid>

        <controls:ComposerBox x:Name="Composer"
                              Grid.Row="2"
                              VerticalAlignment="Bottom" />
    </Grid>
</Page>
