<Page
    x:Class="CodeHarness.Desktop.Views.ChatPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:CodeHarness.Desktop.Controls">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Toolbar -->
        <Border Grid.Row="0"
                Padding="20,12,20,12"
                BorderBrush="{ThemeResource CodeHarnessBorderBrush}"
                BorderThickness="0,0,0,1">
            <Grid>
                <Button Style="{StaticResource ModelPillButtonStyle}" HorizontalAlignment="Left">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Ellipse Width="7" Height="7" VerticalAlignment="Center"
                                 Fill="{ThemeResource CodeHarnessAccentBrush}" />
                        <TextBlock Text="ChatGLM" VerticalAlignment="Center" />
                        <TextBlock Text="&#xE76C;" FontFamily="Segoe MDL2 Assets" FontSize="9"
                                   Foreground="{ThemeResource CodeHarnessMutedTextBrush}"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                </Button>
                <TextBlock x:Name="StatusText"
                           Text="Ready"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           FontSize="12"
                           Foreground="{ThemeResource CodeHarnessMutedTextBrush}" />
                <StackPanel Orientation="Horizontal" Spacing="2" HorizontalAlignment="Right">
                    <Button Style="{StaticResource ToolbarButtonStyle}" Content="Share" />
                    <Button Style="{StaticResource ToolbarButtonStyle}" Content="&#xE81C;"
                            FontFamily="Segoe MDL2 Assets" />
                    <Button Style="{StaticResource ToolbarButtonStyle}" Content="&#xE712;"
                            FontFamily="Segoe MDL2 Assets" />
                </StackPanel>
            </Grid>
        </Border>

        <!-- Content: empty state vs messages -->
        <Grid Grid.Row="1">
            <!-- Empty state -->
            <StackPanel x:Name="EmptyStatePanel"
                        VerticalAlignment="Center"
                        HorizontalAlignment="Center"
                        Spacing="20"
                        MaxWidth="560"
                        Padding="40,0,40,0">
                <Border Width="56" Height="56" CornerRadius="14"
                        Background="{ThemeResource CodeHarnessAccentTintBrush}"
                        HorizontalAlignment="Center">
                    <TextBlock Text="C" Foreground="{ThemeResource CodeHarnessAccentBrush}"
                               FontSize="26" FontWeight="Bold"
                               HorizontalAlignment="Center" VerticalAlignment="Center" />
                </Border>
                <StackPanel Spacing="6" HorizontalAlignment="Center">
                    <TextBlock Text="How can I help you today?" Style="{StaticResource HeroTextStyle}"
                               HorizontalAlignment="Center" />
                    <TextBlock Text="Ask anything about your codebase, or pick a starting point below."
                               Style="{StaticResource HeroSubTextStyle}"
                               HorizontalAlignment="Center" />
                </StackPanel>

                <StackPanel Spacing="8" HorizontalAlignment="Center">
                    <Button x:Name="SuggestionArchitecture"
                            Style="{StaticResource SuggestionChipStyle}"
                            HorizontalAlignment="Stretch"
                            Click="OnSuggestionClick"
                            Tag="Explain the architecture of this project">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <TextBlock Text="&#xE721;" FontFamily="Segoe MDL2 Assets" FontSize="14"
                                       Foreground="{ThemeResource CodeHarnessAccentBrush}" VerticalAlignment="Center" />
                            <TextBlock Text="Explain the architecture of this project" VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>
                    <Button x:Name="SuggestionFixBugs"
                            Style="{StaticResource SuggestionChipStyle}"
                            HorizontalAlignment="Stretch"
                            Click="OnSuggestionClick"
                            Tag="Find and fix bugs in my code">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <TextBlock Text="&#xE943;" FontFamily="Segoe MDL2 Assets" FontSize="14"
                                       Foreground="{ThemeResource CodeHarnessAccentBrush}" VerticalAlignment="Center" />
                            <TextBlock Text="Find and fix bugs in my code" VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>
                    <Button x:Name="SuggestionAddTests"
                            Style="{StaticResource SuggestionChipStyle}"
                            HorizontalAlignment="Stretch"
                            Click="OnSuggestionClick"
                            Tag="Add unit tests for the engine module">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <TextBlock Text="&#xE9D9;" FontFamily="Segoe MDL2 Assets" FontSize="14"
                                       Foreground="{ThemeResource CodeHarnessAccentBrush}" VerticalAlignment="Center" />
                            <TextBlock Text="Add unit tests for the engine module" VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>
                </StackPanel>
            </StackPanel>

            <!-- Messages -->
            <ScrollViewer x:Name="MessagesScroll"
                          VerticalScrollBarVisibility="Auto"
                          Padding="0,24,0,24"
                          Visibility="Collapsed">
                <StackPanel x:Name="MessagesPanel"
                            Spacing="14"
                            MaxWidth="820"
                            HorizontalAlignment="Center" />
            </ScrollViewer>
        </Grid>

        <!-- Composer -->
        <controls:ComposerBox x:Name="Composer" Grid.Row="2" />
    </Grid>
</Page>
