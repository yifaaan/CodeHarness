<Project xmlns="http://schemas.microsoft.com/developer/msbuild/2003">
  <PropertyGroup>
    <ComputeCompileInputsTargets>
      $(ComputeCompileInputsTargets);
      CodeHarnessDesktopMarkupCompile
    </ComputeCompileInputsTargets>
  </PropertyGroup>

  <Target Name="CodeHarnessDesktopMarkupCompile"
          DependsOnTargets="MarkupCompilePass1;MarkupCompilePass2"
          Condition="'@(ApplicationDefinition)' != '' Or '@(Page)' != ''" />
</Project>