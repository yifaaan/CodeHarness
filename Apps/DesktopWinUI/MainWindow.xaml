<Window
    x:Class="CodeHarness.Desktop.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="CodeHarness">

    <Grid Background="{ThemeResource CodeHarnessBackgroundBrush}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="286" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0"
                Background="{ThemeResource CodeHarnessSidebarBrush}"
                BorderBrush="{ThemeResource CodeHarnessBorderBrush}"
                BorderThickness="0,0,1,0">
            <Grid Padding="0,20,0,16">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <StackPanel Spacing="4">
                    <Button x:Name="NewChatButton" Style="{StaticResource SidebarButtonStyle}" Content="New chat" />
                    <Button Style="{StaticResource SidebarButtonStyle}" Content="Search" />
                    <Button Style="{StaticResource SidebarButtonStyle}" Content="Skills" />
                    <Button Style="{StaticResource SidebarButtonStyle}" Content="Plugins" IsEnabled="False" />
                    <Button Style="{StaticResource SidebarButtonStyle}" Content="Automations" />
                </StackPanel>

                <StackPanel Grid.Row="1" Margin="0,28,0,10" Spacing="8">
                    <TextBlock Text="Project" Style="{StaticResource SidebarSectionTextStyle}" />
                    <TextBlock x:Name="WorkdirText" Text="CodeHarness" Style="{StaticResource ProjectTextStyle}" />
                </StackPanel>

                <ListView x:Name="SessionsList"
                          Grid.Row="2"
                          Margin="0,0,0,8"
                          SelectionMode="Single"
                          Background="Transparent" />

                <TextBlock Grid.Row="3"
                           Margin="18,0,18,0"
                           Text="WinUI 3 Desktop MVP"
                           Foreground="{ThemeResource CodeHarnessMutedTextBrush}" />
            </Grid>
        </Border>

        <Grid Grid.Column="1" Padding="64,36,64,36">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <StackPanel Spacing="8" HorizontalAlignment="Center">
                <TextBlock Text="What should we do?" Style="{StaticResource HeroTextStyle}" />
                <TextBlock x:Name="StatusText"
                           Text="Ready"
                           HorizontalAlignment="Center"
                           Foreground="{ThemeResource CodeHarnessMutedTextBrush}" />
            </StackPanel>

            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="0,36,0,24">
                <StackPanel x:Name="MessagesPanel" Spacing="12" MaxWidth="920" HorizontalAlignment="Center" />
            </ScrollViewer>

            <Border Grid.Row="2"
                    MaxWidth="920"
                    HorizontalAlignment="Center"
                    Background="{ThemeResource CodeHarnessComposerBrush}"
                    BorderBrush="{ThemeResource CodeHarnessBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="20"
                    Padding="14">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <TextBox x:Name="PromptBox"
                             PlaceholderText="Ask CodeHarness anything. Type @ to mention files or plugins."
                             AcceptsReturn="True"
                             TextWrapping="Wrap"
                             MinHeight="72"
                             BorderThickness="0"
                             Background="Transparent" />
                    <Grid Grid.Row="1" Margin="0,10,0,0">
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <TextBlock Text="+" FontSize="24" VerticalAlignment="Center" />
                            <TextBlock Text="Manual permission mode" Foreground="{ThemeResource CodeHarnessAccentBrush}" VerticalAlignment="Center" />
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8">
                            <Button x:Name="CancelButton" Content="Cancel" IsEnabled="False" />
                            <Button x:Name="SendButton" Content="Send" Style="{StaticResource AccentButtonStyle}" />
                        </StackPanel>
                    </Grid>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
