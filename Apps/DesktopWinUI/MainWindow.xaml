<Window
    x:Class="CodeHarness.Desktop.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="ChatGLM">

    <Grid Background="{ThemeResource CodeHarnessBackgroundBrush}"
          MinWidth="1040"
          MinHeight="640">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="260" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="300" />
        </Grid.ColumnDefinitions>

        <!-- ============================================================= -->
        <!-- COLUMN 0 · LEFT SIDEBAR                                        -->
        <!-- ============================================================= -->
        <Border Grid.Column="0"
                Background="{ThemeResource CodeHarnessSidebarBrush}"
                BorderBrush="{ThemeResource CodeHarnessBorderBrush}"
                BorderThickness="0,0,1,0">
            <Grid Padding="0,16,0,14">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- Brand -->
                <Grid Margin="18,0,18,4" Height="34">
                    <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                        <Border Width="26" Height="26" CornerRadius="7"
                                Background="{ThemeResource CodeHarnessAccentBrush}">
                            <TextBlock Text="C" Foreground="#FFFFFFFF" FontSize="15" FontWeight="Bold"
                                       HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <TextBlock Text="ChatGLM" Style="{StaticResource BrandTextStyle}" VerticalAlignment="Center" />
                    </StackPanel>
                </Grid>

                <!-- New chat -->
                <StackPanel Grid.Row="1" Margin="0,8,0,4">
                    <Button x:Name="NewChatButton"
                            Style="{StaticResource NewChatButtonStyle}"
                            HorizontalContentAlignment="Left">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <TextBlock Text="+" FontSize="16" FontWeight="Bold"
                                       Foreground="{ThemeResource CodeHarnessAccentHoverBrush}"
                                       VerticalAlignment="Center" />
                            <TextBlock Text="New chat" VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource SidebarButtonStyle}" Content="Search" />
                </StackPanel>

                <!-- Project label -->
                <StackPanel Grid.Row="2" Margin="0,14,0,6">
                    <TextBlock Text="PROJECT" Style="{StaticResource SidebarSectionTextStyle}" Margin="18,0,18,4" />
                    <TextBlock x:Name="WorkdirText" Text="CodeHarness" Style="{StaticResource ProjectTextStyle}" />
                </StackPanel>

                <!-- Sessions list -->
                <Grid Grid.Row="3" Margin="0,4,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <TextBlock Text="CHATS" Style="{StaticResource SidebarSectionTextStyle}" Margin="18,0,18,8" />
                    <ListView x:Name="SessionsList"
                              Grid.Row="1"
                              Margin="4,0,4,8"
                              SelectionMode="Single"
                              Background="Transparent"
                              BorderThickness="0"
                              Padding="0" />
                </Grid>

                <!-- Footer -->
                <Border Grid.Row="4"
                        Margin="10,0,10,0"
                        Padding="10,9,10,9"
                        BorderBrush="{ThemeResource CodeHarnessHairlineBrush}"
                        BorderThickness="0,1,0,0">
                    <Grid>
                        <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                            <Border Width="24" Height="24" CornerRadius="12"
                                    Background="{ThemeResource CodeHarnessAccentSoftBrush}">
                                <TextBlock Text="U" Foreground="{ThemeResource CodeHarnessAccentHoverBrush}"
                                           FontSize="11" FontWeight="SemiBold"
                                           HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Border>
                            <StackPanel Spacing="-1">
                                <TextBlock Text="Guest" FontSize="12" FontWeight="SemiBold"
                                           Foreground="{ThemeResource CodeHarnessPrimaryTextBrush}" />
                                <TextBlock Text="Manual mode" FontSize="11"
                                           Foreground="{ThemeResource CodeHarnessMutedTextBrush}" />
                            </StackPanel>
                        </StackPanel>
                        <Button Style="{StaticResource IconButtonStyle}"
                                HorizontalAlignment="Right"
                                Content="&#xE713;"
                                FontFamily="Segoe MDL2 Assets"
                                Width="28" Height="28" />
                    </Grid>
                </Border>
            </Grid>
        </Border>

        <!-- ============================================================= -->
        <!-- COLUMN 1 · MAIN PANEL                                          -->
        <!-- ============================================================= -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Toolbar -->
            <Border Grid.Row="0"
                    Padding="20,12,20,12"
                    BorderBrush="{ThemeResource CodeHarnessBorderBrush}"
                    BorderThickness="0,0,0,1">
                <Grid>
                    <Button Style="{StaticResource ModelPillButtonStyle}" HorizontalAlignment="Left">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <Ellipse Width="7" Height="7" VerticalAlignment="Center"
                                     Fill="{ThemeResource CodeHarnessAccentBrush}" />
                            <TextBlock Text="ChatGLM" VerticalAlignment="Center" />
                            <TextBlock Text="&#xE76C;" FontFamily="Segoe MDL2 Assets" FontSize="9"
                                       Foreground="{ThemeResource CodeHarnessMutedTextBrush}"
                                       VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>
                    <TextBlock x:Name="StatusText"
                               Text="Ready"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               FontSize="12"
                               Foreground="{ThemeResource CodeHarnessMutedTextBrush}" />
                    <StackPanel Orientation="Horizontal" Spacing="2" HorizontalAlignment="Right">
                        <Button Style="{StaticResource ToolbarButtonStyle}" Content="Share" />
                        <Button Style="{StaticResource ToolbarButtonStyle}" Content="&#xE81C;"
                                FontFamily="Segoe MDL2 Assets" />
                        <Button Style="{StaticResource ToolbarButtonStyle}" Content="&#xE712;"
                                FontFamily="Segoe MDL2 Assets" />
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Content: empty state vs messages -->
            <Grid Grid.Row="1">
                <!-- Empty state -->
                <StackPanel x:Name="EmptyStatePanel"
                            VerticalAlignment="Center"
                            HorizontalAlignment="Center"
                            Spacing="20"
                            MaxWidth="560"
                            Padding="40,0,40,0">
                    <Border Width="56" Height="56" CornerRadius="14"
                            Background="{ThemeResource CodeHarnessAccentTintBrush}"
                            HorizontalAlignment="Center">
                        <TextBlock Text="C" Foreground="{ThemeResource CodeHarnessAccentBrush}"
                                   FontSize="26" FontWeight="Bold"
                                   HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <StackPanel Spacing="6" HorizontalAlignment="Center">
                        <TextBlock Text="How can I help you today?" Style="{StaticResource HeroTextStyle}"
                                   HorizontalAlignment="Center" />
                        <TextBlock Text="Ask anything about your codebase, or pick a starting point below."
                                   Style="{StaticResource HeroSubTextStyle}"
                                   HorizontalAlignment="Center" />
                    </StackPanel>

                    <StackPanel Spacing="8" HorizontalAlignment="Center">
                        <Button Style="{StaticResource SuggestionChipStyle}" HorizontalAlignment="Stretch">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <TextBlock Text="&#xE721;" FontFamily="Segoe MDL2 Assets" FontSize="14"
                                           Foreground="{ThemeResource CodeHarnessAccentBrush}" VerticalAlignment="Center" />
                                <TextBlock Text="Explain the architecture of this project" VerticalAlignment="Center" />
                            </StackPanel>
                        </Button>
                        <Button Style="{StaticResource SuggestionChipStyle}" HorizontalAlignment="Stretch">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <TextBlock Text="&#xE943;" FontFamily="Segoe MDL2 Assets" FontSize="14"
                                           Foreground="{ThemeResource CodeHarnessAccentBrush}" VerticalAlignment="Center" />
                                <TextBlock Text="Find and fix bugs in my code" VerticalAlignment="Center" />
                            </StackPanel>
                        </Button>
                        <Button Style="{StaticResource SuggestionChipStyle}" HorizontalAlignment="Stretch">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <TextBlock Text="&#xE9D9;" FontFamily="Segoe MDL2 Assets" FontSize="14"
                                           Foreground="{ThemeResource CodeHarnessAccentBrush}" VerticalAlignment="Center" />
                                <TextBlock Text="Add unit tests for the engine module" VerticalAlignment="Center" />
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </StackPanel>

                <!-- Messages -->
                <ScrollViewer x:Name="MessagesScroll"
                              VerticalScrollBarVisibility="Auto"
                              Padding="0,24,0,24"
                              Visibility="Collapsed">
                    <StackPanel x:Name="MessagesPanel"
                                Spacing="14"
                                MaxWidth="820"
                                HorizontalAlignment="Center" />
                </ScrollViewer>
            </Grid>

            <!-- Composer -->
            <Border Grid.Row="2"
                    MaxWidth="820"
                    HorizontalAlignment="Center"
                    Margin="20,0,20,18"
                    Background="{ThemeResource CodeHarnessComposerBrush}"
                    BorderBrush="{ThemeResource CodeHarnessBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="20"
                    Padding="14,12,12,12">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <TextBox x:Name="PromptBox"
                             PlaceholderText="Ask ChatGLM anything. Type @ to mention files or plugins."
                             AcceptsReturn="True"
                             TextWrapping="Wrap"
                             MinHeight="24"
                             BorderThickness="0"
                             Background="Transparent"
                             Padding="2,4,2,4"
                             FontSize="14" />

                    <Grid Grid.Row="1" Margin="0,10,0,0">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <Button Style="{StaticResource IconButtonStyle}" Content="+" FontSize="18" />
                            <Border CornerRadius="999" Padding="9,3,9,3"
                                    VerticalAlignment="Center"
                                    Background="{ThemeResource CodeHarnessAccentTintBrush}">
                                <TextBlock Text="Manual permission mode" FontSize="11"
                                           Foreground="{ThemeResource CodeHarnessAccentHoverBrush}" />
                            </Border>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8">
                            <Button x:Name="CancelButton"
                                    Style="{StaticResource CancelRoundButtonStyle}"
                                    Content="&#xE711;"
                                    FontFamily="Segoe MDL2 Assets"
                                    IsEnabled="False" />
                            <Button x:Name="SendButton"
                                    Style="{StaticResource SendButtonStyle}"
                                    Content="&#xE72A;"
                                    FontFamily="Segoe MDL2 Assets" />
                        </StackPanel>
                    </Grid>
                </Grid>
            </Border>
        </Grid>

        <!-- ============================================================= -->
        <!-- COLUMN 2 · RIGHT CONTEXT PANEL                                 -->
        <!-- ============================================================= -->
        <Border Grid.Column="2"
                Background="{ThemeResource CodeHarnessContextPanelBrush}"
                BorderBrush="{ThemeResource CodeHarnessBorderBrush}"
                BorderThickness="1,0,0,0">
            <Grid Padding="18,16,18,14">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <!-- Header -->
                <Grid Grid.Row="0" Margin="0,0,0,18">
                    <TextBlock Text="Context" FontSize="14" FontWeight="SemiBold"
                               Foreground="{ThemeResource CodeHarnessPrimaryTextBrush}" VerticalAlignment="Center" />
                    <Button Style="{StaticResource IconButtonStyle}"
                            HorizontalAlignment="Right"
                            Content="&#xE713;" FontFamily="Segoe MDL2 Assets"
                            Width="28" Height="28" />
                </Grid>

                <!-- Open files -->
                <StackPanel Grid.Row="1" Margin="0,0,0,18" Spacing="8">
                    <TextBlock Text="OPEN FILES" Style="{StaticResource ContextSectionTextStyle}" />
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="&#xE8A5;" FontFamily="Segoe MDL2 Assets" FontSize="13"
                                   Foreground="{ThemeResource CodeHarnessAccentBrush}"
                                   VerticalAlignment="Center" Margin="0,0,9,0" />
                        <TextBlock Grid.Column="1" Text="MainWindow.xaml" Style="{StaticResource ContextItemTextStyle}" />
                        <TextBlock Grid.Column="2" Text="XAML" Style="{StaticResource ContextItemMetaTextStyle}" />
                    </Grid>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="&#xE8A5;" FontFamily="Segoe MDL2 Assets" FontSize="13"
                                   Foreground="{ThemeResource CodeHarnessAccentBrush}"
                                   VerticalAlignment="Center" Margin="0,0,9,0" />
                        <TextBlock Grid.Column="1" Text="MainWindow.xaml.cpp" Style="{StaticResource ContextItemTextStyle}" />
                        <TextBlock Grid.Column="2" Text="C++" Style="{StaticResource ContextItemMetaTextStyle}" />
                    </Grid>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="&#xE8A5;" FontFamily="Segoe MDL2 Assets" FontSize="13"
                                   Foreground="{ThemeResource CodeHarnessMutedTextBrush}"
                                   VerticalAlignment="Center" Margin="0,0,9,0" />
                        <TextBlock Grid.Column="1" Text="Colors.xaml" Style="{StaticResource ContextItemTextStyle}" />
                        <TextBlock Grid.Column="2" Text="XAML" Style="{StaticResource ContextItemMetaTextStyle}" />
                    </Grid>
                </StackPanel>

                <!-- Usage -->
                <StackPanel Grid.Row="2" Margin="0,0,0,18" Spacing="8">
                    <TextBlock Text="USAGE" Style="{StaticResource ContextSectionTextStyle}" />
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Context" Style="{StaticResource ContextItemTextStyle}" />
                        <TextBlock Grid.Column="1" Text="0 / 128k" Style="{StaticResource ContextItemMetaTextStyle}" />
                    </Grid>
                    <ProgressBar Value="0" Maximum="100"
                                 CornerRadius="3"
                                 Height="6"
                                 Foreground="{ThemeResource CodeHarnessAccentBrush}"
                                 Background="{ThemeResource CodeHarnessHoverBrush}" />
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Steps" Style="{StaticResource ContextItemTextStyle}" />
                        <TextBlock Grid.Column="1" Text="0" Style="{StaticResource ContextItemMetaTextStyle}" />
                    </Grid>
                </StackPanel>

                <!-- Activity -->
                <StackPanel Grid.Row="3" Spacing="8">
                    <TextBlock Text="ACTIVITY" Style="{StaticResource ContextSectionTextStyle}" />
                    <TextBlock Text="No recent activity. Start a chat to see tool calls and updates here."
                               Style="{StaticResource ContextItemMetaTextStyle}"
                               TextWrapping="Wrap" />
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
