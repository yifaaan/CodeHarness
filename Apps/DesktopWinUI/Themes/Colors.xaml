<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ===== CodePilot/Luma-inspired neutral shell ===== -->
    <SolidColorBrush x:Key="CodeHarnessWindowBrush" Color="#FFFAFAF9" />
    <SolidColorBrush x:Key="CodeHarnessTopBarBrush" Color="#FFFAFAF9" />
    <SolidColorBrush x:Key="CodeHarnessBackgroundBrush" Color="#FFFAFAF9" />
    <SolidColorBrush x:Key="CodeHarnessMainSurfaceBrush" Color="#FFFFFFFF" />
    <SolidColorBrush x:Key="CodeHarnessSidebarBrush" Color="#FFFAFAF9" />
    <SolidColorBrush x:Key="CodeHarnessContextPanelBrush" Color="#FFFFFFFF" />
    <SolidColorBrush x:Key="CodeHarnessComposerBrush" Color="#FFFFFFFF" />
    <SolidColorBrush x:Key="CodeHarnessCardBrush" Color="#FFFFFFFF" />
    <SolidColorBrush x:Key="CodeHarnessSubtleCardBrush" Color="#FFF5F5F4" />

    <!-- ===== Borders / dividers ===== -->
    <SolidColorBrush x:Key="CodeHarnessBorderBrush" Color="#FFE5E5E2" />
    <SolidColorBrush x:Key="CodeHarnessDividerBrush" Color="#FFEDEDE9" />
    <SolidColorBrush x:Key="CodeHarnessHairlineBrush" Color="#FFF2F2EF" />
    <SolidColorBrush x:Key="CodeHarnessFloatingBorderBrush" Color="#FFE3E3DF" />

    <!-- ===== Text ===== -->
    <SolidColorBrush x:Key="CodeHarnessPrimaryTextBrush" Color="#FF242424" />
    <SolidColorBrush x:Key="CodeHarnessSecondaryTextBrush" Color="#FF585852" />
    <SolidColorBrush x:Key="CodeHarnessMutedTextBrush" Color="#FF85857D" />
    <SolidColorBrush x:Key="CodeHarnessFaintTextBrush" Color="#FFB4B4AC" />

    <!-- ===== Monochrome primary accent ===== -->
    <SolidColorBrush x:Key="CodeHarnessAccentBrush" Color="#FF252525" />
    <SolidColorBrush x:Key="CodeHarnessAccentHoverBrush" Color="#FF111111" />
    <SolidColorBrush x:Key="CodeHarnessAccentSoftBrush" Color="#FFE8E8E4" />
    <SolidColorBrush x:Key="CodeHarnessAccentTintBrush" Color="#FFF1F1EE" />

    <!-- ===== Interactive: hover/press surfaces ===== -->
    <SolidColorBrush x:Key="CodeHarnessHoverBrush" Color="#FFF0F0EC" />
    <SolidColorBrush x:Key="CodeHarnessPressBrush" Color="#FFE5E5E0" />
    <SolidColorBrush x:Key="CodeHarnessSelectedBrush" Color="#FFECECE8" />

    <!-- ===== Message bubbles ===== -->
    <SolidColorBrush x:Key="CodeHarnessUserBubbleBrush" Color="#FFF5F5F4" />
    <SolidColorBrush x:Key="CodeHarnessUserBubbleTextBrush" Color="#FF242424" />
    <SolidColorBrush x:Key="CodeHarnessAssistantBubbleBrush" Color="#FFFFFFFF" />
    <SolidColorBrush x:Key="CodeHarnessToolBubbleBrush" Color="#FFF6F6F4" />

    <!-- ===== Status ===== -->
    <SolidColorBrush x:Key="CodeHarnessReadyDotBrush" Color="#FF252525" />
    <SolidColorBrush x:Key="CodeHarnessBusyDotBrush" Color="#FFD97706" />

    <!-- ===== Git panel helpers ===== -->
    <SolidColorBrush x:Key="GitAddedBrush" Color="#FF16A34A" />
    <SolidColorBrush x:Key="GitModifiedBrush" Color="#FFCA8A04" />
    <SolidColorBrush x:Key="GitDeletedBrush" Color="#FFDC2626" />

</ResourceDictionary>
