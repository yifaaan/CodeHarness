<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ===== Base surfaces (light theme, white per request) ===== -->
    <SolidColorBrush x:Key="CodeHarnessBackgroundBrush" Color="#FFFFFFFF" />
    <SolidColorBrush x:Key="CodeHarnessSidebarBrush" Color="#FFF7F8F7" />
    <SolidColorBrush x:Key="CodeHarnessContextPanelBrush" Color="#FFF7F8F7" />
    <SolidColorBrush x:Key="CodeHarnessComposerBrush" Color="#FFFFFFFF" />
    <SolidColorBrush x:Key="CodeHarnessCardBrush" Color="#FFFFFFFF" />

    <!-- ===== Borders / dividers ===== -->
    <SolidColorBrush x:Key="CodeHarnessBorderBrush" Color="#FFE6E7E5" />
    <SolidColorBrush x:Key="CodeHarnessDividerBrush" Color="#FFEFEEEC" />
    <SolidColorBrush x:Key="CodeHarnessHairlineBrush" Color="#FFF0F0EE" />

    <!-- ===== Text ===== -->
    <SolidColorBrush x:Key="CodeHarnessPrimaryTextBrush" Color="#FF1F1F1E" />
    <SolidColorBrush x:Key="CodeHarnessSecondaryTextBrush" Color="#FF5C5C58" />
    <SolidColorBrush x:Key="CodeHarnessMutedTextBrush" Color="#FF8A8A86" />
    <SolidColorBrush x:Key="CodeHarnessFaintTextBrush" Color="#FFAEACA7" />

    <!-- ===== CodeHarness blue accent (brand) ===== -->
    <SolidColorBrush x:Key="CodeHarnessAccentBrush" Color="#FF2563EB" />
    <SolidColorBrush x:Key="CodeHarnessAccentHoverBrush" Color="#FF1D4ED8" />
    <SolidColorBrush x:Key="CodeHarnessAccentSoftBrush" Color="#FFDBEAFE" />
    <SolidColorBrush x:Key="CodeHarnessAccentTintBrush" Color="#FFEFF6FF" />

    <!-- ===== Interactive: hover/press surfaces ===== -->
    <SolidColorBrush x:Key="CodeHarnessHoverBrush" Color="#FFEFEEEC" />
    <SolidColorBrush x:Key="CodeHarnessPressBrush" Color="#FFE6E7E5" />
    <SolidColorBrush x:Key="CodeHarnessSelectedBrush" Color="#FFE8EAE7" />

    <!-- ===== Message bubbles ===== -->
    <SolidColorBrush x:Key="CodeHarnessUserBubbleBrush" Color="#FFEFF6FF" />
    <SolidColorBrush x:Key="CodeHarnessAssistantBubbleBrush" Color="#FFF6F6F5" />
    <SolidColorBrush x:Key="CodeHarnessToolBubbleBrush" Color="#FFFAFAF9" />

    <!-- ===== Status ===== -->
    <SolidColorBrush x:Key="CodeHarnessReadyDotBrush" Color="#FF2563EB" />
    <SolidColorBrush x:Key="CodeHarnessBusyDotBrush" Color="#FFD97706" />

    <!-- ===== Git panel helpers ===== -->
    <SolidColorBrush x:Key="GitAddedBrush" Color="#FF16A34A" />
    <SolidColorBrush x:Key="GitModifiedBrush" Color="#FFCA8A04" />
    <SolidColorBrush x:Key="GitDeletedBrush" Color="#FFDC2626" />

</ResourceDictionary>