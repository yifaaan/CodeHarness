<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!--
        Shared button template: on hover/pressed it ONLY swaps the background,
        never the foreground. This fixes the white-text-on-hover bug where the
        default WinUI template overrides Foreground to white in PointerOver state.
    -->
    <ControlTemplate x:Key="PlainButtonTemplate" TargetType="Button">
        <Border x:Name="Root"
                Background="{TemplateBinding Background}"
                BorderBrush="{TemplateBinding BorderBrush}"
                BorderThickness="{TemplateBinding BorderThickness}"
                CornerRadius="{TemplateBinding CornerRadius}">
            <ContentPresenter x:Name="ContentPresenter"
                              Content="{TemplateBinding Content}"
                              ContentTemplate="{TemplateBinding ContentTemplate}"
                              ContentTransitions="{TemplateBinding ContentTransitions}"
                              Padding="{TemplateBinding Padding}"
                              HorizontalContentAlignment="{TemplateBinding HorizontalContentAlignment}"
                              VerticalContentAlignment="{TemplateBinding VerticalContentAlignment}"
                              Foreground="{TemplateBinding Foreground}" />
            <VisualStateManager.VisualStateGroups>
                <VisualStateGroup x:Name="CommonStates">
                    <VisualState x:Name="Normal" />
                    <VisualState x:Name="PointerOver">
                        <VisualState.Setters>
                            <Setter Target="Root.Background" Value="{ThemeResource CodeHarnessHoverBrush}" />
                        </VisualState.Setters>
                    </VisualState>
                    <VisualState x:Name="Pressed">
                        <VisualState.Setters>
                            <Setter Target="Root.Background" Value="{ThemeResource CodeHarnessPressBrush}" />
                        </VisualState.Setters>
                    </VisualState>
                    <VisualState x:Name="Disabled">
                        <VisualState.Setters>
                            <Setter Target="ContentPresenter.Opacity" Value="0.4" />
                        </VisualState.Setters>
                    </VisualState>
                </VisualStateGroup>
            </VisualStateManager.VisualStateGroups>
        </Border>
    </ControlTemplate>

    <!-- Green-tint button template (New chat): hover deepens the green tint, keeps dark-green text. -->
    <ControlTemplate x:Key="GreenTintButtonTemplate" TargetType="Button">
        <Border x:Name="Root"
                Background="{TemplateBinding Background}"
                BorderBrush="{TemplateBinding BorderBrush}"
                BorderThickness="{TemplateBinding BorderThickness}"
                CornerRadius="{TemplateBinding CornerRadius}">
            <ContentPresenter x:Name="ContentPresenter"
                              Content="{TemplateBinding Content}"
                              ContentTemplate="{TemplateBinding ContentTemplate}"
                              ContentTransitions="{TemplateBinding ContentTransitions}"
                              Padding="{TemplateBinding Padding}"
                              HorizontalContentAlignment="{TemplateBinding HorizontalContentAlignment}"
                              VerticalContentAlignment="{TemplateBinding VerticalContentAlignment}"
                              Foreground="{TemplateBinding Foreground}" />
            <VisualStateManager.VisualStateGroups>
                <VisualStateGroup x:Name="CommonStates">
                    <VisualState x:Name="Normal" />
                    <VisualState x:Name="PointerOver">
                        <VisualState.Setters>
                            <Setter Target="Root.Background" Value="{ThemeResource CodeHarnessAccentSoftBrush}" />
                        </VisualState.Setters>
                    </VisualState>
                    <VisualState x:Name="Pressed">
                        <VisualState.Setters>
                            <Setter Target="Root.Background" Value="{ThemeResource CodeHarnessAccentSoftBrush}" />
                            <Setter Target="ContentPresenter.Opacity" Value="0.7" />
                        </VisualState.Setters>
                    </VisualState>
                    <VisualState x:Name="Disabled">
                        <VisualState.Setters>
                            <Setter Target="ContentPresenter.Opacity" Value="0.4" />
                        </VisualState.Setters>
                    </VisualState>
                </VisualStateGroup>
            </VisualStateManager.VisualStateGroups>
        </Border>
    </ControlTemplate>

    <!-- Solid green (Send): hover/pressed darkens green, keeps white text. -->
    <ControlTemplate x:Key="AccentRoundButtonTemplate" TargetType="Button">
        <Border x:Name="Root"
                Background="{TemplateBinding Background}"
                BorderBrush="{TemplateBinding BorderBrush}"
                BorderThickness="{TemplateBinding BorderThickness}"
                CornerRadius="{TemplateBinding CornerRadius}">
            <ContentPresenter x:Name="ContentPresenter"
                              Content="{TemplateBinding Content}"
                              ContentTemplate="{TemplateBinding ContentTemplate}"
                              ContentTransitions="{TemplateBinding ContentTransitions}"
                              Padding="{TemplateBinding Padding}"
                              HorizontalContentAlignment="Center"
                              VerticalContentAlignment="Center"
                              Foreground="{TemplateBinding Foreground}" />
            <VisualStateManager.VisualStateGroups>
                <VisualStateGroup x:Name="CommonStates">
                    <VisualState x:Name="Normal" />
                    <VisualState x:Name="PointerOver">
                        <VisualState.Setters>
                            <Setter Target="Root.Background" Value="{ThemeResource CodeHarnessAccentHoverBrush}" />
                        </VisualState.Setters>
                    </VisualState>
                    <VisualState x:Name="Pressed">
                        <VisualState.Setters>
                            <Setter Target="Root.Background" Value="{ThemeResource CodeHarnessAccentHoverBrush}" />
                            <Setter Target="ContentPresenter.Opacity" Value="0.8" />
                        </VisualState.Setters>
                    </VisualState>
                    <VisualState x:Name="Disabled">
                        <VisualState.Setters>
                            <Setter Target="Root.Background" Value="{ThemeResource CodeHarnessFaintTextBrush}" />
                        </VisualState.Setters>
                    </VisualState>
                </VisualStateGroup>
            </VisualStateManager.VisualStateGroups>
        </Border>
    </ControlTemplate>

    <!-- ===== Sidebar nav / action buttons ===== -->
    <Style x:Key="SidebarButtonStyle" TargetType="Button">
        <Setter Property="Template" Value="{StaticResource PlainButtonTemplate}" />
        <Setter Property="HorizontalAlignment" Value="Stretch" />
        <Setter Property="HorizontalContentAlignment" Value="Left" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="Margin" Value="8,2,8,2" />
        <Setter Property="Padding" Value="10,8,10,8" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="CornerRadius" Value="8" />
        <Setter Property="Foreground" Value="{ThemeResource CodeHarnessPrimaryTextBrush}" />
        <Setter Property="FontSize" Value="13" />
    </Style>

    <!-- "+ New chat" — green-tint primary in the sidebar header -->
    <Style x:Key="NewChatButtonStyle" TargetType="Button">
        <Setter Property="Template" Value="{StaticResource GreenTintButtonTemplate}" />
        <Setter Property="HorizontalAlignment" Value="Stretch" />
        <Setter Property="HorizontalContentAlignment" Value="Left" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="Margin" Value="8,2,8,2" />
        <Setter Property="Padding" Value="10,9,10,9" />
        <Setter Property="Background" Value="{ThemeResource CodeHarnessAccentTintBrush}" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="CornerRadius" Value="8" />
        <Setter Property="Foreground" Value="{ThemeResource CodeHarnessAccentHoverBrush}" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="FontSize" Value="13" />
    </Style>

    <!-- ===== Toolbar buttons (model row) ===== -->
    <Style x:Key="ToolbarButtonStyle" TargetType="Button">
        <Setter Property="Template" Value="{StaticResource PlainButtonTemplate}" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="CornerRadius" Value="6" />
        <Setter Property="Padding" Value="8,6,8,6" />
        <Setter Property="Foreground" Value="{ThemeResource CodeHarnessSecondaryTextBrush}" />
        <Setter Property="FontSize" Value="13" />
    </Style>

    <Style x:Key="ModelPillButtonStyle" TargetType="Button">
        <Setter Property="Template" Value="{StaticResource PlainButtonTemplate}" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="BorderBrush" Value="{ThemeResource CodeHarnessBorderBrush}" />
        <Setter Property="CornerRadius" Value="999" />
        <Setter Property="Padding" Value="12,5,10,5" />
        <Setter Property="Foreground" Value="{ThemeResource CodeHarnessPrimaryTextBrush}" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="FontWeight" Value="Medium" />
    </Style>

    <!-- ===== Icon buttons (composer attach, gear) ===== -->
    <Style x:Key="IconButtonStyle" TargetType="Button">
        <Setter Property="Template" Value="{StaticResource PlainButtonTemplate}" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="CornerRadius" Value="6" />
        <Setter Property="Padding" Value="6,6,6,6" />
        <Setter Property="Foreground" Value="{ThemeResource CodeHarnessSecondaryTextBrush}" />
        <Setter Property="FontSize" Value="16" />
        <Setter Property="Width" Value="30" />
        <Setter Property="Height" Value="30" />
    </Style>

    <!-- ===== Circular green send button ===== -->
    <Style x:Key="SendButtonStyle" TargetType="Button">
        <Setter Property="Template" Value="{StaticResource AccentRoundButtonTemplate}" />
        <Setter Property="Background" Value="{ThemeResource CodeHarnessAccentBrush}" />
        <Setter Property="Foreground" Value="#FFFFFFFF" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="CornerRadius" Value="16" />
        <Setter Property="Width" Value="32" />
        <Setter Property="Height" Value="32" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="FontSize" Value="15" />
    </Style>

    <Style x:Key="CancelRoundButtonStyle" TargetType="Button">
        <Setter Property="Template" Value="{StaticResource PlainButtonTemplate}" />
        <Setter Property="Background" Value="{ThemeResource CodeHarnessHoverBrush}" />
        <Setter Property="Foreground" Value="{ThemeResource CodeHarnessSecondaryTextBrush}" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="CornerRadius" Value="16" />
        <Setter Property="Width" Value="32" />
        <Setter Property="Height" Value="32" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="FontSize" Value="13" />
    </Style>

    <!-- Legacy alias kept for any external reference (formerly grey Send) -->
    <Style x:Key="AccentButtonStyle" TargetType="Button" BasedOn="{StaticResource SendButtonStyle}" />

    <!-- ===== Suggestion chips (empty state) ===== -->
    <Style x:Key="SuggestionChipStyle" TargetType="Button">
        <Setter Property="Template" Value="{StaticResource PlainButtonTemplate}" />
        <Setter Property="Background" Value="{ThemeResource CodeHarnessCardBrush}" />
        <Setter Property="BorderBrush" Value="{ThemeResource CodeHarnessBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="10" />
        <Setter Property="Padding" Value="14,10,14,10" />
        <Setter Property="HorizontalContentAlignment" Value="Left" />
        <Setter Property="Foreground" Value="{ThemeResource CodeHarnessPrimaryTextBrush}" />
        <Setter Property="FontSize" Value="13" />
    </Style>

    <!-- ===== Tool call cards (collapsible rows in the transcript) ===== -->
    <Style x:Key="ToolCardBorderStyle" TargetType="Border">
        <Setter Property="Background" Value="{ThemeResource CodeHarnessToolBubbleBrush}" />
        <Setter Property="BorderBrush" Value="{ThemeResource CodeHarnessBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="10" />
        <Setter Property="Padding" Value="12,9,12,9" />
        <Setter Property="HorizontalAlignment" Value="Stretch" />
    </Style>

    <Style x:Key="ToolCardErrorBorderStyle" TargetType="Border" BasedOn="{StaticResource ToolCardBorderStyle}">
        <Setter Property="Background" Value="#FFFFF4F4" />
        <Setter Property="BorderBrush" Value="#FFF5C6C6" />
    </Style>

    <!-- ===== Git panel styles ===== -->

    <Style x:Key="GitBranchPillStyle" TargetType="Border">
        <Setter Property="CornerRadius" Value="8" />
        <Setter Property="Padding" Value="10,8,10,8" />
        <Setter Property="Background" Value="{ThemeResource CodeHarnessCardBrush}" />
        <Setter Property="BorderBrush" Value="{ThemeResource CodeHarnessBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
    </Style>

    <Style x:Key="GitTabHeaderActiveStyle" TargetType="Border">
        <Setter Property="Padding" Value="0,8,0,8" />
        <Setter Property="BorderBrush" Value="{ThemeResource CodeHarnessAccentBrush}" />
        <Setter Property="BorderThickness" Value="0,0,0,2" />
    </Style>

    <Style x:Key="GitTabHeaderInactiveStyle" TargetType="Border">
        <Setter Property="Padding" Value="0,8,0,8" />
        <Setter Property="BorderBrush" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0,0,0,2" />
    </Style>

    <Style x:Key="GitFileChangeRowStyle" TargetType="Grid">
        <Setter Property="Padding" Value="0,2,0,2" />
        <Setter Property="ColumnSpacing" Value="6" />
    </Style>

    <Style x:Key="GitActionButtonStyle" TargetType="Button" BasedOn="{StaticResource ToolbarButtonStyle}">
        <Setter Property="FontSize" Value="11" />
        <Setter Property="Padding" Value="6,3,6,3" />
        <Setter Property="CornerRadius" Value="6" />
    </Style>

    <!-- ===== Markdown / thinking block styles ===== -->

    <Style x:Key="MarkdownCodeBlockBorder" TargetType="Border">
        <Setter Property="Background" Value="#FFF3F4F6" />
        <Setter Property="BorderBrush" Value="{ThemeResource CodeHarnessBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="6" />
        <Setter Property="Padding" Value="12,10,12,10" />
        <Setter Property="Margin" Value="0,4,0,4" />
    </Style>

    <Style x:Key="ThinkingBlockStyle" TargetType="Border">
        <Setter Property="Background" Value="#FFFAFAF9" />
        <Setter Property="BorderBrush" Value="{ThemeResource CodeHarnessBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="8" />
        <Setter Property="Padding" Value="12,8,12,8" />
        <Setter Property="Margin" Value="0,4,0,8" />
    </Style>

</ResourceDictionary>
