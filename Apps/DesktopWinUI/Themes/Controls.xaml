<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ===== Sidebar nav / action buttons ===== -->
    <Style x:Key="SidebarButtonStyle" TargetType="Button">
        <Setter Property="HorizontalAlignment" Value="Stretch" />
        <Setter Property="HorizontalContentAlignment" Value="Left" />
        <Setter Property="Margin" Value="8,2,8,2" />
        <Setter Property="Padding" Value="10,8,10,8" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="CornerRadius" Value="8" />
        <Setter Property="Foreground" Value="{ThemeResource CodeHarnessPrimaryTextBrush}" />
        <Setter Property="FontSize" Value="13" />
    </Style>

    <!-- "+ New chat" — green-filled primary in the sidebar header -->
    <Style x:Key="NewChatButtonStyle" TargetType="Button">
        <Setter Property="HorizontalAlignment" Value="Stretch" />
        <Setter Property="HorizontalContentAlignment" Value="Left" />
        <Setter Property="Margin" Value="8,2,8,2" />
        <Setter Property="Padding" Value="10,9,10,9" />
        <Setter Property="Background" Value="{ThemeResource CodeHarnessAccentTintBrush}" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="CornerRadius" Value="8" />
        <Setter Property="Foreground" Value="{ThemeResource CodeHarnessAccentHoverBrush}" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="FontSize" Value="13" />
    </Style>

    <!-- ===== Toolbar buttons (model row) ===== -->
    <Style x:Key="ToolbarButtonStyle" TargetType="Button">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="CornerRadius" Value="6" />
        <Setter Property="Padding" Value="8,6,8,6" />
        <Setter Property="Foreground" Value="{ThemeResource CodeHarnessSecondaryTextBrush}" />
        <Setter Property="FontSize" Value="13" />
    </Style>

    <Style x:Key="ModelPillButtonStyle" TargetType="Button">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="BorderBrush" Value="{ThemeResource CodeHarnessBorderBrush}" />
        <Setter Property="CornerRadius" Value="999" />
        <Setter Property="Padding" Value="12,5,10,5" />
        <Setter Property="Foreground" Value="{ThemeResource CodeHarnessPrimaryTextBrush}" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="FontWeight" Value="Medium" />
    </Style>

    <!-- ===== Icon buttons (composer attach, etc.) ===== -->
    <Style x:Key="IconButtonStyle" TargetType="Button">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="CornerRadius" Value="6" />
        <Setter Property="Padding" Value="6,6,6,6" />
        <Setter Property="Foreground" Value="{ThemeResource CodeHarnessSecondaryTextBrush}" />
        <Setter Property="FontSize" Value="16" />
        <Setter Property="Width" Value="30" />
        <Setter Property="Height" Value="30" />
    </Style>

    <!-- ===== Circular green send button ===== -->
    <Style x:Key="SendButtonStyle" TargetType="Button">
        <Setter Property="Background" Value="{ThemeResource CodeHarnessAccentBrush}" />
        <Setter Property="Foreground" Value="#FFFFFFFF" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="CornerRadius" Value="16" />
        <Setter Property="Width" Value="32" />
        <Setter Property="Height" Value="32" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="FontSize" Value="15" />
    </Style>

    <Style x:Key="CancelRoundButtonStyle" TargetType="Button">
        <Setter Property="Background" Value="{ThemeResource CodeHarnessHoverBrush}" />
        <Setter Property="Foreground" Value="{ThemeResource CodeHarnessSecondaryTextBrush}" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="CornerRadius" Value="16" />
        <Setter Property="Width" Value="32" />
        <Setter Property="Height" Value="32" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="FontSize" Value="13" />
    </Style>

    <!-- Legacy alias kept for any external reference (formerly grey Send) -->
    <Style x:Key="AccentButtonStyle" TargetType="Button" BasedOn="{StaticResource SendButtonStyle}" />

    <!-- ===== Suggestion chips (empty state) ===== -->
    <Style x:Key="SuggestionChipStyle" TargetType="Button">
        <Setter Property="Background" Value="{ThemeResource CodeHarnessCardBrush}" />
        <Setter Property="BorderBrush" Value="{ThemeResource CodeHarnessBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="10" />
        <Setter Property="Padding" Value="14,10,14,10" />
        <Setter Property="HorizontalContentAlignment" Value="Left" />
        <Setter Property="Foreground" Value="{ThemeResource CodeHarnessPrimaryTextBrush}" />
        <Setter Property="FontSize" Value="13" />
    </Style>

    <!-- ===== Small status pill in sidebar footer ===== -->
    <Style x:Key="StatusPillStyle" TargetType="Border">
        <Setter Property="CornerRadius" Value="999" />
        <Setter Property="Padding" Value="8,3,10,3" />
        <Setter Property="Background" Value="{ThemeResource CodeHarnessAccentTintBrush}" />
    </Style>

</ResourceDictionary>
