namespace CodeHarness.Desktop.Controls
{
	[default_interface]
	runtimeclass Sidebar : Microsoft.UI.Xaml.Controls.UserControl
	{
		Sidebar();

		void SetSessions(Windows.Foundation.Collections.IVectorView<String> sessions);
		void SetSessionsWithTimestamps(Windows.Foundation.Collections.IVectorView<String> titles,
		                               Windows.Foundation.Collections.IVectorView<Int64> createdAtMs);
		void SetSessionItems(Windows.Foundation.Collections.IVectorView<String> titles,
		                     Windows.Foundation.Collections.IVectorView<String> sessionIds,
		                     Windows.Foundation.Collections.IVectorView<Int64> createdAtMs);
		void SetActiveSession(String title);
		void SetWorkdir(String workdir);
		void Focus();

		// XAML-wired event handlers.
		void OnNewChatClick(Object sender, Microsoft.UI.Xaml.RoutedEventArgs args);
		void OnSessionDoubleTapped(Object sender, Microsoft.UI.Xaml.Input.DoubleTappedRoutedEventArgs args);
		void OnSettingsClick(Object sender, Microsoft.UI.Xaml.RoutedEventArgs args);
		void OnSearchClick(Object sender, Microsoft.UI.Xaml.RoutedEventArgs args);
		void OnSearchTextChanged(Object sender, Microsoft.UI.Xaml.Controls.TextChangedEventArgs args);
		void OnSearchClose(Object sender, Microsoft.UI.Xaml.RoutedEventArgs args);
	}
}
