<UserControl
    x:Class="CodeHarness.Desktop.Controls.Sidebar"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Border Background="{ThemeResource CodeHarnessSidebarBrush}"
            BorderBrush="{ThemeResource CodeHarnessBorderBrush}"
            BorderThickness="0,0,1,0">
        <Grid Padding="0,16,0,14">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Brand -->
            <Grid Margin="18,0,18,4" Height="34">
                <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                    <Border Width="26" Height="26" CornerRadius="7"
                            Background="{ThemeResource CodeHarnessAccentBrush}">
                        <TextBlock Text="C" Foreground="#FFFFFFFF" FontSize="15" FontWeight="Bold"
                                   HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <TextBlock Text="CodeHarness" Style="{StaticResource BrandTextStyle}" VerticalAlignment="Center" />
                </StackPanel>
            </Grid>

            <!-- New chat + Search -->
            <StackPanel Grid.Row="1" Margin="0,8,0,4">
                <Button x:Name="NewChatBtn"
                        Style="{StaticResource NewChatButtonStyle}"
                        HorizontalContentAlignment="Left"
                        Click="OnNewChatClick">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <TextBlock Text="+" FontSize="16" FontWeight="Bold"
                                   Foreground="{ThemeResource CodeHarnessAccentHoverBrush}"
                                   VerticalAlignment="Center" />
                        <TextBlock Text="新建会话" VerticalAlignment="Center" />
                    </StackPanel>
                </Button>

                <!-- Search toggle button -->
                <Button x:Name="SearchBtn"
                        Style="{StaticResource SidebarButtonStyle}"
                        HorizontalContentAlignment="Left"
                        Click="OnSearchClick">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <TextBlock Text="&#xE71D;" FontFamily="Segoe MDL2 Assets" FontSize="13"
                                   VerticalAlignment="Center" />
                        <TextBlock Text="搜索" VerticalAlignment="Center" />
                    </StackPanel>
                </Button>

                <!-- Search input (hidden by default, toggled by SearchBtn) -->
                <Border x:Name="SearchBoxPanel"
                        Visibility="Collapsed"
                        Margin="8,4,8,4"
                        Background="{ThemeResource CodeHarnessCardBrush}"
                        BorderBrush="{ThemeResource CodeHarnessBorderBrush}"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="8,2,8,2"
                        Height="34">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="&#xE71D;" FontFamily="Segoe MDL2 Assets"
                                   FontSize="13" Foreground="{ThemeResource CodeHarnessMutedTextBrush}"
                                   VerticalAlignment="Center" Margin="4,0,6,0" />
                        <TextBox x:Name="SearchBox"
                                 Grid.Column="1"
                                 PlaceholderText="搜索会话..."
                                 BorderThickness="0"
                                 Background="Transparent"
                                 FontSize="13"
                                 VerticalAlignment="Center"
                                 Padding="0"
                                 TextChanged="OnSearchTextChanged" />
                        <Button x:Name="SearchCloseBtn"
                                Grid.Column="2"
                                Style="{StaticResource IconButtonStyle}"
                                Content="&#xE711;"
                                FontFamily="Segoe MDL2 Assets"
                                Width="24" Height="24"
                                FontSize="10"
                                Click="OnSearchClose" />
                    </Grid>
                </Border>
            </StackPanel>

            <!-- Project -->
            <StackPanel Grid.Row="2" Margin="0,14,0,6">
                <TextBlock Text="工作区" Style="{StaticResource SidebarSectionTextStyle}" Margin="18,0,18,4" />
                <TextBlock x:Name="WorkdirText" Text="CodeHarness" Style="{StaticResource ProjectTextStyle}" />
            </StackPanel>

            <!-- Session groups -->
            <ScrollViewer Grid.Row="3" Margin="0,4,0,0"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollMode="Disabled"
                          HorizontalScrollBarVisibility="Disabled">
                <StackPanel>
                    <!-- TODAY -->
                    <TextBlock x:Name="TodayHeader"
                               Text="今天"
                               Style="{StaticResource SidebarSectionTextStyle}"
                               Margin="18,0,18,8" />
                    <StackPanel x:Name="TodayGroup" Margin="4,0,4,4" />

                    <!-- PREVIOUS 7 DAYS -->
                    <TextBlock x:Name="WeekHeader"
                               Text="最近7天"
                               Style="{StaticResource SidebarSectionTextStyle}"
                               Margin="18,14,18,8"
                               Visibility="Collapsed" />
                    <StackPanel x:Name="WeekGroup" Margin="4,0,4,4" />

                    <!-- PREVIOUS 30 DAYS -->
                    <TextBlock x:Name="MonthHeader"
                               Text="最近30天"
                               Style="{StaticResource SidebarSectionTextStyle}"
                               Margin="18,14,18,8"
                               Visibility="Collapsed" />
                    <StackPanel x:Name="MonthGroup" Margin="4,0,4,4" />

                    <!-- EARLIER -->
                    <TextBlock x:Name="EarlierHeader"
                               Text="更早"
                               Style="{StaticResource SidebarSectionTextStyle}"
                               Margin="18,14,18,8"
                               Visibility="Collapsed" />
                    <StackPanel x:Name="EarlierGroup" Margin="4,0,4,4" />
                </StackPanel>
            </ScrollViewer>

            <!-- Footer -->
            <Border Grid.Row="4"
                    Margin="10,0,10,0"
                    Padding="10,9,10,9"
                    BorderBrush="{ThemeResource CodeHarnessHairlineBrush}"
                    BorderThickness="0,1,0,0">
                <Grid>
                    <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                        <Border Width="24" Height="24" CornerRadius="12"
                                Background="{ThemeResource CodeHarnessAccentSoftBrush}">
                            <TextBlock Text="U" Foreground="{ThemeResource CodeHarnessAccentHoverBrush}"
                                       FontSize="11" FontWeight="SemiBold"
                                       HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <StackPanel Spacing="-1">
                            <TextBlock Text="用户" FontSize="12" FontWeight="SemiBold"
                                       Foreground="{ThemeResource CodeHarnessPrimaryTextBrush}" />
                            <TextBlock Text="手动模式" FontSize="11"
                                       Foreground="{ThemeResource CodeHarnessMutedTextBrush}" />
                        </StackPanel>
                    </StackPanel>
                    <Button x:Name="SettingsBtn"
                            Style="{StaticResource IconButtonStyle}"
                            HorizontalAlignment="Right"
                            Content="&#xE713;"
                            FontFamily="Segoe MDL2 Assets"
                            Width="28" Height="28"
                            Click="OnSettingsClick" />
                </Grid>
            </Border>
        </Grid>
    </Border>
</UserControl>