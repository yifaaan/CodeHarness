<UserControl
    x:Class="CodeHarness.Desktop.Controls.Sidebar"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Padding="0,8,0,8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Quick actions -->
        <StackPanel Grid.Row="0" Margin="0,0,0,6" Spacing="1">
            <Button x:Name="NewChatBtn"
                    Style="{StaticResource NewChatButtonStyle}"
                    HorizontalContentAlignment="Left"
                    Click="OnNewChatClick">
                <StackPanel Orientation="Horizontal" Spacing="9">
                    <TextBlock Text="&#xE710;"
                               FontFamily="Segoe MDL2 Assets"
                               FontSize="13"
                               VerticalAlignment="Center" />
                    <TextBlock Text="新建会话" VerticalAlignment="Center" />
                </StackPanel>
            </Button>

            <Button x:Name="SearchBtn"
                    Style="{StaticResource SidebarButtonStyle}"
                    HorizontalContentAlignment="Left"
                    Click="OnSearchClick">
                <StackPanel Orientation="Horizontal" Spacing="9">
                    <TextBlock Text="&#xE721;"
                               FontFamily="Segoe MDL2 Assets"
                               FontSize="13"
                               VerticalAlignment="Center" />
                    <TextBlock Text="搜索会话" VerticalAlignment="Center" />
                    <Border Margin="8,0,0,0"
                            Padding="5,1,5,1"
                            CornerRadius="4"
                            Background="{ThemeResource CodeHarnessSubtleCardBrush}">
                        <TextBlock Text="Ctrl K"
                                   FontSize="10"
                                   Foreground="{ThemeResource CodeHarnessMutedTextBrush}" />
                    </Border>
                </StackPanel>
            </Button>

            <Button Style="{StaticResource SidebarButtonStyle}"
                    HorizontalContentAlignment="Left"
                    IsEnabled="False">
                <StackPanel Orientation="Horizontal" Spacing="9">
                    <TextBlock Text="&#xECAA;"
                               FontFamily="Segoe MDL2 Assets"
                               FontSize="13"
                               VerticalAlignment="Center" />
                    <TextBlock Text="插件" VerticalAlignment="Center" />
                </StackPanel>
            </Button>

            <Button Style="{StaticResource SidebarButtonStyle}"
                    HorizontalContentAlignment="Left"
                    IsEnabled="False">
                <StackPanel Orientation="Horizontal" Spacing="9">
                    <TextBlock Text="&#xEB9F;"
                               FontFamily="Segoe MDL2 Assets"
                               FontSize="13"
                               VerticalAlignment="Center" />
                    <TextBlock Text="图库" VerticalAlignment="Center" />
                </StackPanel>
            </Button>

            <Border x:Name="SearchBoxPanel"
                    Visibility="Collapsed"
                    Margin="8,5,8,3"
                    Background="{ThemeResource CodeHarnessCardBrush}"
                    BorderBrush="{ThemeResource CodeHarnessBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="12"
                    Padding="8,2,8,2"
                    Height="36">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0"
                               Text="&#xE721;"
                               FontFamily="Segoe MDL2 Assets"
                               FontSize="13"
                               Foreground="{ThemeResource CodeHarnessMutedTextBrush}"
                               VerticalAlignment="Center"
                               Margin="4,0,6,0" />
                    <TextBox x:Name="SearchBox"
                             Grid.Column="1"
                             PlaceholderText="搜索会话..."
                             BorderThickness="0"
                             Background="Transparent"
                             FontSize="13"
                             VerticalAlignment="Center"
                             Padding="0"
                             TextChanged="OnSearchTextChanged" />
                    <Button x:Name="SearchCloseBtn"
                            Grid.Column="2"
                            Style="{StaticResource IconButtonStyle}"
                            Content="&#xE711;"
                            FontFamily="Segoe MDL2 Assets"
                            Width="24"
                            Height="24"
                            FontSize="10"
                            Click="OnSearchClose" />
                </Grid>
            </Border>
        </StackPanel>

        <!-- Project section -->
        <StackPanel Grid.Row="1" Margin="0,2,0,4" Spacing="1">
            <Grid Margin="10,0,10,0" Height="28">
                <StackPanel Orientation="Horizontal" Spacing="5" VerticalAlignment="Center">
                    <TextBlock Text="项目"
                               Style="{StaticResource SidebarSectionTextStyle}"
                               Margin="0" />
                    <TextBlock Text="&#xE70D;"
                               FontFamily="Segoe MDL2 Assets"
                               FontSize="10"
                               Foreground="{ThemeResource CodeHarnessMutedTextBrush}"
                               VerticalAlignment="Center" />
                </StackPanel>
            </Grid>

            <Button Style="{StaticResource SidebarButtonStyle}"
                    HorizontalContentAlignment="Left"
                    IsTabStop="False">
                <StackPanel Orientation="Horizontal" Spacing="9">
                    <TextBlock Text="&#xE8F4;"
                               FontFamily="Segoe MDL2 Assets"
                               FontSize="13"
                               Foreground="{ThemeResource CodeHarnessMutedTextBrush}"
                               VerticalAlignment="Center" />
                    <TextBlock Text="新建项目" VerticalAlignment="Center" />
                </StackPanel>
            </Button>

            <Border Margin="8,0,8,0"
                    Padding="10,7,10,7"
                    CornerRadius="12"
                    Background="Transparent">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <TextBlock Text="&#xE8B7;"
                               FontFamily="Segoe MDL2 Assets"
                               FontSize="13"
                               Foreground="{ThemeResource CodeHarnessSecondaryTextBrush}"
                               VerticalAlignment="Center" />
                    <TextBlock x:Name="WorkdirText"
                               Text="CodeHarness"
                               Style="{StaticResource ProjectTextStyle}"
                               Margin="0"
                               TextTrimming="CharacterEllipsis" />
                </StackPanel>
            </Border>
        </StackPanel>

        <!-- Session groups -->
        <ScrollViewer Grid.Row="2"
                      Margin="0,4,0,0"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollMode="Disabled"
                      HorizontalScrollBarVisibility="Disabled">
            <StackPanel>
                <Border x:Name="SplitGroupPanel"
                        Visibility="Collapsed"
                        Margin="8,0,8,8"
                        Padding="6"
                        CornerRadius="10"
                        Background="{ThemeResource CodeHarnessSubtleCardBrush}"
                        BorderBrush="{ThemeResource CodeHarnessBorderBrush}"
                        BorderThickness="1">
                    <StackPanel Spacing="2">
                        <StackPanel Orientation="Horizontal"
                                    Spacing="6"
                                    Padding="8,4,8,2">
                            <TextBlock Text="&#xE8A7;"
                                       FontFamily="Segoe MDL2 Assets"
                                       FontSize="12"
                                       Foreground="{ThemeResource CodeHarnessMutedTextBrush}"
                                       VerticalAlignment="Center" />
                            <TextBlock Text="&#x5206;&#x5C4F;"
                                       Style="{StaticResource SidebarSectionTextStyle}"
                                       Margin="0"
                                       VerticalAlignment="Center" />
                        </StackPanel>
                        <StackPanel x:Name="SplitGroupRows" />
                    </StackPanel>
                </Border>

                <TextBlock x:Name="TodayHeader"
                           Text="今天"
                           Style="{StaticResource SidebarSectionTextStyle}"
                           Margin="14,6,14,7" />
                <StackPanel x:Name="TodayGroup" Margin="4,0,4,4" />

                <TextBlock x:Name="WeekHeader"
                           Text="最近 7 天"
                           Style="{StaticResource SidebarSectionTextStyle}"
                           Margin="14,14,14,7"
                           Visibility="Collapsed" />
                <StackPanel x:Name="WeekGroup" Margin="4,0,4,4" />

                <TextBlock x:Name="MonthHeader"
                           Text="最近 30 天"
                           Style="{StaticResource SidebarSectionTextStyle}"
                           Margin="14,14,14,7"
                           Visibility="Collapsed" />
                <StackPanel x:Name="MonthGroup" Margin="4,0,4,4" />

                <TextBlock x:Name="EarlierHeader"
                           Text="更早"
                           Style="{StaticResource SidebarSectionTextStyle}"
                           Margin="14,14,14,7"
                           Visibility="Collapsed" />
                <StackPanel x:Name="EarlierGroup" Margin="4,0,4,4" />
            </StackPanel>
        </ScrollViewer>

        <!-- Footer -->
        <Grid Grid.Row="3" Margin="8,8,8,0">
            <Button x:Name="SettingsBtn"
                    Style="{StaticResource SidebarButtonStyle}"
                    HorizontalContentAlignment="Left"
                    Click="OnSettingsClick">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <Border Width="24"
                            Height="24"
                            CornerRadius="12"
                            Background="{ThemeResource CodeHarnessSubtleCardBrush}">
                        <TextBlock Text="U"
                                   Foreground="{ThemeResource CodeHarnessSecondaryTextBrush}"
                                   FontSize="11"
                                   FontWeight="SemiBold"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center" />
                    </Border>
                    <StackPanel Grid.Column="1" Margin="8,0,0,0" VerticalAlignment="Center">
                        <TextBlock Text="用户"
                                   FontSize="12"
                                   FontWeight="SemiBold"
                                   Foreground="{ThemeResource CodeHarnessPrimaryTextBrush}" />
                        <TextBlock Text="手动模式"
                                   FontSize="11"
                                   Foreground="{ThemeResource CodeHarnessMutedTextBrush}" />
                    </StackPanel>
                    <TextBlock Grid.Column="2"
                               Text="&#xE713;"
                               FontFamily="Segoe MDL2 Assets"
                               FontSize="14"
                               Foreground="{ThemeResource CodeHarnessMutedTextBrush}"
                               VerticalAlignment="Center" />
                </Grid>
            </Button>
        </Grid>
    </Grid>
</UserControl>
