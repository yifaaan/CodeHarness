<UserControl
    x:Class="CodeHarness.Desktop.Controls.ComposerBox"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Padding="16,8,16,6"
          Background="Transparent">
        <Border MaxWidth="768"
                HorizontalAlignment="Center"
                Background="{ThemeResource CodeHarnessComposerBrush}"
                BorderBrush="{ThemeResource CodeHarnessBorderBrush}"
                BorderThickness="1"
                CornerRadius="22"
                Padding="0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <ScrollViewer x:Name="AttachmentScroll"
                              Grid.Row="0"
                              Margin="12,10,12,0"
                              HorizontalScrollMode="Auto"
                              HorizontalScrollBarVisibility="Hidden"
                              VerticalScrollMode="Disabled"
                              VerticalScrollBarVisibility="Disabled"
                              Visibility="Collapsed">
                    <StackPanel x:Name="AttachmentPanel"
                                Orientation="Horizontal"
                                Spacing="6" />
                </ScrollViewer>

                <TextBox x:Name="PromptBox"
                         Grid.Row="1"
                         PlaceholderText="向 CodeHarness 描述你的下一步..."
                         AcceptsReturn="True"
                         TextWrapping="Wrap"
                         MinHeight="48"
                         MaxHeight="180"
                         BorderThickness="0"
                         Background="Transparent"
                         Padding="16,12,16,8"
                         FontSize="14"
                         KeyDown="OnPromptKeyDown" />

                <Grid Grid.Row="2" Margin="12,0,10,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <ScrollViewer Grid.Column="0"
                                  HorizontalScrollMode="Auto"
                                  HorizontalScrollBarVisibility="Hidden"
                                  VerticalScrollMode="Disabled"
                                  VerticalScrollBarVisibility="Disabled">
                    <StackPanel Orientation="Horizontal"
                                Spacing="7"
                                VerticalAlignment="Center">
                        <Button x:Name="ActionMenuButton"
                                Style="{StaticResource IconButtonStyle}"
                                Content="&#xE710;"
                                FontFamily="Segoe MDL2 Assets"
                                FontSize="14"
                                Width="28"
                                Height="28"
                                Click="OnActionMenuClick" />

                        <Button x:Name="ModeSelectorButton"
                                Style="{StaticResource ModelPillButtonStyle}"
                                Click="OnModeSelectorClick">
                            <StackPanel Orientation="Horizontal" Spacing="5">
                                <TextBlock Text="&#xE943;"
                                           FontFamily="Segoe MDL2 Assets"
                                           FontSize="12"
                                           Foreground="{ThemeResource CodeHarnessMutedTextBrush}"
                                           VerticalAlignment="Center" />
                                <TextBlock Text="Code"
                                           FontSize="12"
                                           VerticalAlignment="Center" />
                                <TextBlock Text="&#xE70D;"
                                           FontFamily="Segoe MDL2 Assets"
                                           FontSize="8"
                                           Foreground="{ThemeResource CodeHarnessMutedTextBrush}"
                                           VerticalAlignment="Center" />
                            </StackPanel>
                        </Button>

                        <Button x:Name="ModelSelectorButton"
                                Style="{StaticResource ModelPillButtonStyle}"
                                Click="OnModelSelectorClick">
                            <StackPanel Orientation="Horizontal" Spacing="5">
                                <TextBlock Text="&#xE8D4;"
                                           FontFamily="Segoe MDL2 Assets"
                                           FontSize="12"
                                           Foreground="{ThemeResource CodeHarnessMutedTextBrush}"
                                           VerticalAlignment="Center" />
                                <TextBlock x:Name="ModelNameText"
                                           Text="GLM 5.2"
                                           FontSize="12"
                                           VerticalAlignment="Center" />
                                <TextBlock Text="&#xE70D;"
                                           FontFamily="Segoe MDL2 Assets"
                                           FontSize="8"
                                           Foreground="{ThemeResource CodeHarnessMutedTextBrush}"
                                           VerticalAlignment="Center" />
                            </StackPanel>
                        </Button>

                        <Button x:Name="ThinkingToggle"
                                Style="{StaticResource ModelPillButtonStyle}"
                                Click="OnThinkingClick">
                            <StackPanel Orientation="Horizontal" Spacing="5">
                                <Ellipse x:Name="ThinkingDot"
                                         Width="7"
                                         Height="7"
                                         Fill="{ThemeResource CodeHarnessMutedTextBrush}"
                                         VerticalAlignment="Center" />
                                <TextBlock Text="思考"
                                           FontSize="12"
                                           VerticalAlignment="Center" />
                            </StackPanel>
                        </Button>

                        <Button x:Name="PermissionSelectorButton"
                                Style="{StaticResource ModelPillButtonStyle}"
                                Click="OnPermissionSelectorClick">
                            <StackPanel Orientation="Horizontal" Spacing="5">
                                <TextBlock Text="&#xE72E;"
                                           FontFamily="Segoe MDL2 Assets"
                                           FontSize="11"
                                           Foreground="{ThemeResource CodeHarnessSecondaryTextBrush}"
                                           VerticalAlignment="Center" />
                                <TextBlock Text="Manual"
                                           FontSize="12"
                                           VerticalAlignment="Center" />
                                <TextBlock Text="&#xE70D;"
                                           FontFamily="Segoe MDL2 Assets"
                                           FontSize="8"
                                           Foreground="{ThemeResource CodeHarnessMutedTextBrush}"
                                           VerticalAlignment="Center" />
                            </StackPanel>
                        </Button>
                    </StackPanel>
                    </ScrollViewer>

                    <StackPanel Grid.Column="1"
                                Orientation="Horizontal"
                                HorizontalAlignment="Right"
                                Spacing="8"
                                VerticalAlignment="Center">
                        <Button x:Name="CancelButton"
                                Style="{StaticResource CancelRoundButtonStyle}"
                                Content="&#xE711;"
                                FontFamily="Segoe MDL2 Assets"
                                Width="28"
                                Height="28"
                                Click="OnCancelClick"
                                IsEnabled="False" />
                        <Button x:Name="SendButton"
                                Style="{StaticResource SendButtonStyle}"
                                Content="&#xE72A;"
                                FontFamily="Segoe MDL2 Assets"
                                Width="30"
                                Height="30"
                                Click="OnSendClick" />
                    </StackPanel>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</UserControl>
