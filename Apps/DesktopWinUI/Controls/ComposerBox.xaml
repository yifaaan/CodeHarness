<UserControl
    x:Class="CodeHarness.Desktop.Controls.ComposerBox"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Border MaxWidth="820"
            HorizontalAlignment="Center"
            Margin="20,0,20,18"
            Background="{ThemeResource CodeHarnessComposerBrush}"
            BorderBrush="{ThemeResource CodeHarnessBorderBrush}"
            BorderThickness="1"
            CornerRadius="20"
            Padding="14,12,12,12">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <TextBox x:Name="PromptBox"
                     PlaceholderText="请描述您想要的操作..."
                     AcceptsReturn="True"
                     TextWrapping="Wrap"
                     MinHeight="24"
                     BorderThickness="0"
                     Background="Transparent"
                     Padding="2,4,2,4"
                     FontSize="14"
                     KeyDown="OnPromptKeyDown" />

            <Grid Grid.Row="1" Margin="0,10,0,0">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <Button Style="{StaticResource IconButtonStyle}" Content="+" FontSize="18" />
                    <Border CornerRadius="999" Padding="9,3,9,3"
                            VerticalAlignment="Center"
                            Background="{ThemeResource CodeHarnessAccentTintBrush}">
                        <StackPanel Orientation="Horizontal" Spacing="4">
                            <TextBlock Text="&#xE72E;" FontFamily="Segoe MDL2 Assets" FontSize="10"
                                       Foreground="{ThemeResource CodeHarnessAccentHoverBrush}"
                                       VerticalAlignment="Center" />
                            <TextBlock Text="手动授权" FontSize="11"
                                       Foreground="{ThemeResource CodeHarnessAccentHoverBrush}" />
                        </StackPanel>
                    </Border>

                    <!-- Model selector button -->
                    <Button x:Name="ModelSelectorButton"
                            Style="{StaticResource ToolbarButtonStyle}"
                            Click="OnModelSelectorClick">
                        <StackPanel Orientation="Horizontal" Spacing="4">
                            <TextBlock x:Name="ModelNameText"
                                       Text="GLM 5.2"
                                       FontSize="12"
                                       VerticalAlignment="Center" />
                            <TextBlock Text="&#xE76C;" FontFamily="Segoe MDL2 Assets" FontSize="9"
                                       Foreground="{ThemeResource CodeHarnessMutedTextBrush}"
                                       VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>

                    <!-- Thinking toggle -->
                    <Button x:Name="ThinkingToggle"
                            Style="{StaticResource ToolbarButtonStyle}"
                            Click="OnThinkingClick">
                        <StackPanel Orientation="Horizontal" Spacing="4">
                            <Ellipse x:Name="ThinkingDot"
                                     Width="7" Height="7"
                                     Fill="{ThemeResource CodeHarnessMutedTextBrush}"
                                     VerticalAlignment="Center" />
                            <TextBlock Text="思考" FontSize="12"
                                       VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>
                </StackPanel>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8">
                    <Button x:Name="CancelButton"
                            Style="{StaticResource CancelRoundButtonStyle}"
                            Content="&#xE711;"
                            FontFamily="Segoe MDL2 Assets"
                            Click="OnCancelClick"
                            IsEnabled="False" />
                    <Button x:Name="SendButton"
                            Style="{StaticResource SendButtonStyle}"
                            Content="&#xE72A;"
                            FontFamily="Segoe MDL2 Assets"
                            Click="OnSendClick" />
                </StackPanel>
            </Grid>
        </Grid>
    </Border>
</UserControl>